# airflow-demo example env. Copy to .env and edit locally. Do not commit .env.

COMPOSE_PROJECT_NAME=airflow-demo
PROJECT_ROOT=/home/jiucheng/project/airflow-demo
SHARED_ROOT=/home/jiucheng/project/airflow-demo/shared
CONTAINER_SHARED_ROOT=/data/airflow-demo
AIRFLOW_DEMO_TZ=Asia/Shanghai

DOCKER_SUBNET=172.30.10.0/24
DOCKER_GATEWAY=172.30.10.1
AIRFLOW_API_IP=172.30.10.10
AIRFLOW_SCHEDULER_IP=172.30.10.11
AIRFLOW_WORKER_IP=172.30.10.12
BACKEND_IP=172.30.10.20
FRONTEND_IP=172.30.10.30
POSTGRES_IP=172.30.10.40
REDIS_IP=172.30.10.50
MAILHOG_IP=172.30.10.60

BACKEND_PORT=8000
FRONTEND_PORT=12959
AIRFLOW_PORT=12958
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

AIRFLOW_IMAGE=airflow-demo/airflow:0.1.0
BACKEND_IMAGE=airflow-demo/backend:0.1.0
FRONTEND_IMAGE=airflow-demo/frontend:0.1.0
SNAKEMAKE_RUNNER_IMAGE=airflow-demo/snakemake-runner:0.1.0
# On Linux servers, set this to `id -u` for the deploy user that owns ./shared.
# fengxian jiucheng uid is 1005; do not reuse blindly on BS10610.
AIRFLOW_UID=1005
AIRFLOW_DAGS_ROOT=/opt/airflow/dags
AIRFLOW_PIPELINES_ROOT=/opt/airflow/pipelines
AIRFLOW_PROFILES_ROOT=/opt/airflow/profiles
AIRFLOW_BASE_URL=http://airflow-api-server:8080
AIRFLOW_DEFAULT_TIMEZONE=Asia/Shanghai
AIRFLOW_DEFAULT_UI_TIMEZONE=Asia/Shanghai
AIRFLOW_API_USERNAME=admin
AIRFLOW_API_PASSWORD=<CHANGE_ME_LOCAL_ONLY>
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=<CHANGE_ME_LOCAL_ONLY>
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=airflow-demo@example.com
BACKEND_BASE_URL=http://backend:8000
FRONTEND_BASE_URL=http://localhost:12959
FRONTEND_DISPLAY_TIME_ZONE=Asia/Shanghai
BACKEND_CORS_ORIGINS=*

POSTGRES_USER=airflow
POSTGRES_PASSWORD=<CHANGE_ME_LOCAL_ONLY>
POSTGRES_DB=airflow
BIODEMO_DB=biodemo
BIODEMO_USER=biodemo
BIODEMO_PASSWORD=<CHANGE_ME_LOCAL_ONLY>
DATABASE_URL=postgresql+psycopg://biodemo:<CHANGE_ME_LOCAL_ONLY>@postgres:5432/biodemo

PGTA_PIPELINE_ROOT=/home/jiucheng/pipelines/PGT_A
PGTA_CONTAINER_ROOT=/opt/pipelines/PGT_A
BIOSOFTWARE_ROOT=/biosoftware
PGTA_SNAKEMAKE9_BIN=/biosoftware/miniconda/envs/snakemake9_env/bin/snakemake
PGTA_SNAKEMAKE_CORES=64
PGTA_PYTHON_BIN=/biosoftware/miniconda/envs/snakemake_env/bin/python
PGTA_CONDA_LIB=/biosoftware/miniconda/envs/snakemake_env/lib
PGTA_DATA_ROOT=/data/project/CNV/PGT-A
PGTA_CONTAINER_DATA_ROOT=/data/project/CNV/PGT-A
REFERENCE_ROOT=/data/Database
CONTAINER_REFERENCE_ROOT=/data/Database
PGTA_REFERENCE_GENOME=/data/Database/index/hg19/hg19.fa
PGTA_SAMTOOLS_BIN=/biosoftware/miniconda/pkgs/samtools-1.7-1/bin/samtools
PGTA_SAMTOOLS_LIBRARY_PATH=/biosoftware/miniconda/pkgs/openssl-1.0.2u-h516909a_0/lib
INPUT_SCAN_ROOTS=/data/project/CNV/PGT-A/rawdata

SMTP_HOST=mailhog
SMTP_PORT=1025
MAIL_FROM=airflow-demo@example.com

QSUB_QUEUE=demo
MAX_DEMO_JOBS=20
ALLOW_REAL_QSUB=false
AIRFLOW_DEMO_QSUB_MODE=mock
AIRFLOW_DEMO_QSUB_PYTHON=python
