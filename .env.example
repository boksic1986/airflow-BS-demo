# airflow-demo example env. Copy to .env and fill locally. Do not commit .env.

PROJECT_ROOT=<TO_BE_FILLED>
SHARED_ROOT=<TO_BE_FILLED>
AIRFLOW_BASE_URL=http://airflow-api-server:8080
BACKEND_BASE_URL=http://backend:8000
FRONTEND_BASE_URL=http://localhost:3000

POSTGRES_USER=airflow
POSTGRES_PASSWORD=<CHANGE_ME_LOCAL_ONLY>
POSTGRES_DB=airflow
BIODEMO_DB=biodemo
BIODEMO_USER=demo
BIODEMO_PASSWORD=<CHANGE_ME_LOCAL_ONLY>
DATABASE_URL=postgresql+psycopg://demo:<CHANGE_ME_LOCAL_ONLY>@postgres:5432/biodemo

SMTP_HOST=mailhog
SMTP_PORT=1025
MAIL_FROM=airflow-demo@example.com

QSUB_QUEUE=<TO_BE_FILLED>
MAX_DEMO_JOBS=20
ALLOW_REAL_QSUB=false
